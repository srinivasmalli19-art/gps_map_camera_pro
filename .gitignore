# The .vscode folder contains launch configuration and tasks you configure in VS Code
.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android build outputs — never commit these
/android/app/build/
/android/build/
/android/.gradle/
/android/app/debug
/android/app/profile
/android/app/release

# CMake / NDK intermediate files — machine-specific, must not be committed
android/app/.cxx/

# Auto-generated Flutter plugin registrant — regenerated on every flutter pub get
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# local.properties contains the Flutter SDK path — never commit this
android/local.properties

# Release signing — NEVER commit these
android/key.properties
android/app/release.jks
